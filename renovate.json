{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>plopoyop/renovate-config",
    "github>plopoyop/renovate-config:kubernetes-ansible-collection",
    "github>plopoyop/renovate-config:automerge-devbox"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "mongodb-kubernetes"
      ],
      "registryUrls": [
        "https://mongodb.github.io/helm-charts"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "mongodb-instance"
      ],
      "registryUrls": [
        "https://plopoyop.github.io/charts"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "postgresql-instance"
      ],
      "registryUrls": [
        "https://plopoyop.github.io/charts"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "postgres-operator"
      ],
      "registryUrls": [
        "https://opensource.zalando.com/postgres-operator/charts/postgres-operator"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "postgres-operator-ui"
      ],
      "registryUrls": [
        "https://opensource.zalando.com/postgres-operator/charts/postgres-operator-ui"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "mariadb-operator"
      ],
      "registryUrls": [
        "https://helm.mariadb.com/mariadb-operator"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "mariadb-operator-crds"
      ],
      "registryUrls": [
        "https://helm.mariadb.com/mariadb-operator"
      ]
    },{
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "mariadb-cluster"
      ],
      "registryUrls": [
        "https://helm.mariadb.com/mariadb-operator"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mongodb_operator/defaults/main.yml$/",
        "/roles/mongodb_operator/README.md$/"
      ],
      "matchStrings": [
        "mongodb_operator_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "mongodb-kubernetes",
      "autoReplaceStringTemplate": "mongodb_operator_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "MongoDb for Kubernetes\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "mongodb-kubernetes",
      "autoReplaceStringTemplate": "MongoDb for Kubernetes | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mongodb_instance/defaults/main.yml$/",
        "/roles/mongodb_instance/README.md$/"
      ],
      "matchStrings": [
        "mongodb_instance_crd_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "mongodb-instance",
      "autoReplaceStringTemplate": "mongodb_instance_crd_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "MongoDb Instance\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "mongodb-instance",
      "autoReplaceStringTemplate": "MongoDb Instance | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/postgres_operator/defaults/main.yml$/",
        "/roles/postgres_operator/README.md$/"
      ],
      "matchStrings": [
        "postgres_operator_helm_chart_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "postgres-operator",
      "autoReplaceStringTemplate": "postgres_operator_helm_chart_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Postgres Operator\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "postgres-operator",
      "autoReplaceStringTemplate": "Postgres Operator | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/postgres_operator/defaults/main.yml$/",
        "/roles/postgres_operator/README.md$/"
      ],
      "matchStrings": [
        "postgres_operator_ui_helm_chart_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "postgres-operator-ui",
      "autoReplaceStringTemplate": "postgres_operator_ui_helm_chart_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/postgres_instance/defaults/main.yml$/",
        "/roles/postgres_instance/README.md$/"
      ],
      "matchStrings": [
        "postgres_instance_crd_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "postgresql-instance",
      "autoReplaceStringTemplate": "postgres_instance_crd_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Postgres Instance\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "postgresql-instance",
      "autoReplaceStringTemplate": "Postgres Instance | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mariadb_operator/defaults/main.yml$/",
        "/roles/mariadb_operator/README.md$/"
      ],
      "matchStrings": [
        "mariadb_operator_helm_chart_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "mariadb-operator",
      "autoReplaceStringTemplate": "mariadb_operator_helm_chart_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mariadb_operator/defaults/main.yml$/",
        "/roles/mariadb_operator/README.md$/"
      ],
      "matchStrings": [
        "mariadb_operator_crds_helm_chart_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "mariadb-operator-crds",
      "autoReplaceStringTemplate": "mariadb_operator_crds_helm_chart_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "MariaDB Operator\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "mariadb-operator",
      "autoReplaceStringTemplate": "MariaDB Operator  | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mariadb_instance/defaults/main.yml$/",
        "/roles/mariadb_instance/README.md$/"
      ],
      "matchStrings": [
        "mariadb_instance_crd_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "mariadb-cluster",
      "autoReplaceStringTemplate": "mariadb_instance_crd_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "MariaDB Instance\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "mariadb-cluster",
      "autoReplaceStringTemplate": "MariaDB Instance  | v{{newValue}}",
      "datasourceTemplate": "helm"
    }
  ]
}
